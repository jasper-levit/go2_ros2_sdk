# ROS 2 Jazzy on Ubuntu 24.04 (Noble) for Unitree Go2 WEBRTC
FROM ros:jazzy-ros-base

# Install basic requirements
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    gnupg2 \
    lsb-release \
    python3-pip \
    python3.12-venv \
    portaudio19-dev \
    mesa-utils \
    libgl1 \
    libgl1-mesa-dri \
    ros-jazzy-rviz2 \
    ros-jazzy-sensor-msgs-py \
    ros-jazzy-slam-toolbox \
    ros-jazzy-nav2-bringup \
    ros-jazzy-foxglove-bridge \
    software-properties-common \
    ros-jazzy-rmw-cyclonedds-cpp \
    ffmpeg

# Isolated venv keeps pip packages (aiortc, pydub, etc.) separate from system Python.
# colcon build runs WITHOUT the venv so ROS build tools (empy, catkin_pkg) are found
# on the system; the generated wrapper scripts get shebang #!/usr/bin/python3.
# At runtime PYTHONPATH is set (see entrypoint) so #!/usr/bin/python3 scripts find
# the venv packages.
RUN python3 -m venv /opt/venv && . /opt/venv/bin/activate && \
    pip install --upgrade pip 'numpy<2.0.0'

# Create workspace
WORKDIR /ros2_ws

# Copy the repository (build context is repo root)
COPY . /ros2_ws/src

# Initialize git submodules (aioice required by go2_driver_node for WebRTC)
RUN cd /ros2_ws/src && git submodule update --init --recursive

# Install Python requirements in venv (open3d skipped on arm64/Python 3.12 - optional for lidar map save only)
RUN . /opt/venv/bin/activate && cd src && \
    grep -v '^open3d' requirements.txt > /tmp/requirements_docker.txt && \
    pip install -r /tmp/requirements_docker.txt

# Install ROS dependencies (ignore failures for optional packages not yet in Jazzy)
RUN . /opt/ros/${ROS_DISTRO}/setup.sh && \
    rosdep update && \
    rosdep install --from-paths src --ignore-src -r -y || true

# Build WITHOUT venv so ROS code-generation tools (empy, catkin_pkg) are available.
# Wrapper scripts get shebang #!/usr/bin/python3; PYTHONPATH in the entrypoint
# makes them find the venv packages at runtime.
RUN . /opt/ros/${ROS_DISTRO}/setup.sh && \
    colcon build

# Source venv and ROS2 and workspace in bashrc
RUN echo "source /opt/venv/bin/activate" >> /root/.bashrc && \
    echo "source /opt/ros/${ROS_DISTRO}/setup.bash" >> /root/.bashrc && \
    echo "source /ros2_ws/install/setup.bash" >> /root/.bashrc

# Set environment variables for WEBRTC
ENV ROBOT_IP=""
ENV CONN_TYPE="webrtc"
ENV WEBRTC_SERVER_HOST="0.0.0.0"
ENV WEBRTC_SERVER_PORT="9991"

# Remove apt cache
RUN rm -rf /var/lib/apt/lists/*

# Add venv and workspace to the entrypoint so nodes use venv Python
RUN sed --in-place --expression \
      '$i. /opt/venv/bin/activate' \
      /ros_entrypoint.sh && \
    sed --in-place --expression \
      '$isource "/ros2_ws/install/setup.bash"' \
      /ros_entrypoint.sh

# Start Foxglove Bridge in the background (port 8765), then run the main command
RUN printf '%s\n' \
    '#!/bin/bash' \
    'set -e' \
    '. /opt/venv/bin/activate' \
    'source /opt/ros/${ROS_DISTRO}/setup.bash' \
    'source /ros2_ws/install/setup.bash' \
    '# Expose venv site-packages to #!/usr/bin/python3 wrapper scripts generated by colcon' \
    'export PYTHONPATH=/opt/venv/lib/python3.12/site-packages${PYTHONPATH:+:}${PYTHONPATH}' \
    '# Foxglove Bridge in background for Foxglove Studio (ws://localhost:8765)' \
    'ros2 launch foxglove_bridge foxglove_bridge_launch.xml port:=8765 address:=0.0.0.0 &' \
    'sleep 2' \
    'exec "$@"' \
    > /ros2_foxglove_entrypoint.sh && chmod +x /ros2_foxglove_entrypoint.sh

ENTRYPOINT ["/ros2_foxglove_entrypoint.sh"]
# Default: run minimal WEBRTC launch (driver + state publisher + camera)
# Foxglove Bridge already running in background on port 8765; disable duplicate in launch
# Override with: docker compose run unitree_ros ros2 launch go2_robot_sdk robot.launch.py
CMD ["ros2", "launch", "go2_robot_sdk", "webrtc_web.launch.py", "enable_foxglove_bridge:=false", "enable_tts:=false"]
